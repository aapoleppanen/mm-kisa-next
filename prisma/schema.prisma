// schema.prisma
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ScoringMode {
  FIXED_ODDS
  COMPRESSED_ODDS
  PARI_MUTUEL
  EXACT_SCORE
}

enum Stage {
  GROUP
  R16
  QF
  SF
  FINAL
}

model Config {
  id                  Int         @id @default(1)
  scoringMode         ScoringMode @default(FIXED_ODDS)
  startingCredits     Float       @default(500) @db.Real
  maxBetAmount        Float       @default(50) @db.Real
  lockLeadHours       Int         @default(1)
  prePicksLockAt      DateTime?
  rakePercent         Float       @default(0) @db.Real
  exactScorePoints    Int         @default(3)
  goalDiffPoints      Int         @default(2)
  tendencyPoints      Int         @default(1)
  maintenanceMode     Boolean     @default(false)
  cronSecret          String?
  winnerBonusFactor   Float       @default(10) @db.Real
  topScorerBonusFactor Float      @default(10) @db.Real
  actualWinnerTeamId  Int?
  actualTopScorerId   Int?
  lastCronRunAt       DateTime?
  updatedAt           DateTime    @updatedAt
}

model Tournament {
  id                  Int      @id @default(autoincrement())
  name                String
  fdCompetition       String
  veikkausCtids       String
  startDate           DateTime
  veikkausWinnerEvent String
  veikkausScorerEvent String
  isActive            Boolean  @default(false)
}

model TeamNameAlias {
  id           Int    @id @default(autoincrement())
  veikkausName String @unique
  teamId       Int
  team         Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Team {
  id          Int             @id @default(autoincrement())
  name        String          @unique
  homeMatches Match[]         @relation("homeMatchs")
  awayMatches Match[]         @relation("awayMatchs")
  crest       String
  winningOdds Int             @default(0)
  User        User[]
  aliases     TeamNameAlias[]
}

model Match {
  id               Int       @id @default(autoincrement())
  startTime        DateTime
  homeId           Int
  awayId           Int
  homeGoals        Int?
  awayGoals        Int?
  home             Team      @relation(name: "homeMatchs", fields: [homeId], references: [id])
  away             Team      @relation(name: "awayMatchs", fields: [awayId], references: [id])
  Pick             Pick[]    @relation("matchPicks")
  Comment          Comment[]
  awayWinOdds      Int       @default(0)
  homeWinOdds      Int       @default(0)
  drawOdds         Int       @default(0)
  result           Result?
  stage            Stage     @default(GROUP)
  resultOverridden Boolean   @default(false)
}

model Player {
  id   Int    @id @default(autoincrement())
  name String @unique
  odds Int    @default(0)
  User User[]
}

enum Result {
  HOME_TEAM
  AWAY_TEAM
  DRAW
  NO_RESULT
}

model Pick {
  id            Int     @id @default(autoincrement())
  matchId       Int
  match         Match   @relation(name: "matchPicks", fields: [matchId], references: [id])
  userId        String
  user          User    @relation(name: "userPicks", fields: [userId], references: [id])
  pickedResult  Result?
  betAmount     Float   @default(0) @db.Real
  predHome      Int?
  predAway      Int?
  awardedPoints Float   @default(0) @db.Real

  @@index([userId, matchId])
  @@unique([userId, matchId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  matchId   Int
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// better-auth tables
model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  emailVerified    Boolean   @default(false)
  image            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  picks            Pick[]    @relation("userPicks")
  comments         Comment[]
  winnerPick       Team?     @relation(fields: [teamId], references: [id])
  topScorerPick    Player?   @relation(fields: [playerId], references: [id])
  sessions         Session[]
  accounts         Account[]
  teamId           Int?
  playerId         Int?
  credits          Float     @default(500) @db.Real
  remainingCredits Float     @default(0) @db.Real
  points           Float     @default(0) @db.Real
  role             String?
  banned           Boolean?
  banReason        String?
  banExpires       DateTime?

  @@index([id])
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
}
